    "crm:seed": "tsx --env-file=.env.local scripts/seed-crm.ts",
    "presentation:voice": "tsx scripts/presentation/generate-voice.ts",
    "presentation:capture": "tsx scripts/presentation/capture.ts",
    "presentation:render": "remotion render remotion/src/index.ts Presentation out/presentation.mp4",
    "reel:render": "remotion render remotion/src/index.ts Reel out/reel.mp4",
    "reel2:render": "remotion render remotion/src/index.ts ReelV2 out/reel-v2.mp4",
