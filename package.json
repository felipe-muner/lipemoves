{
  "name": "lipemoves",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "remotion": "remotion studio remotion/src/index.ts",
    "render:intro": "remotion render remotion/src/index.ts ShoulderIntro out/intro.mp4 --config remotion/remotion.config.ts",
